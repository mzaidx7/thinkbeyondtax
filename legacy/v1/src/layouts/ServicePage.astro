---
import Base from "./Base.astro";
import CtaBand from "../components/CtaBand.astro";
import { platformStates } from "../data/platforms";

interface Props {
  title: string;
  overline?: string;
  intro: string;
  covers: string[];
  metaTitle?: string;
}

const { title, overline = "Services", intro, covers, metaTitle } = Astro.props;
---

<Base title={metaTitle ?? `${title} — Think Beyond Tax`} description={intro}>
  <section class="svc-hero hex-bg">
    <div class="container">
      <p class="overline">{overline}</p>
      <h1>{title}</h1>
      <p class="svc-intro">{intro}</p>
    </div>
  </section>

  <section class="section">
    <div class="container svc-body">
      <div>
        <h2>What this covers</h2>
        <ul class="covers">
          {covers.map((c) => <li>{c}</li>)}
        </ul>
        <slot />
      </div>
      <aside class="svc-aside">
        <p class="overline">Systems we work in</p>
        <ul class="svc-platforms">
          {platformStates.map((p) => <li>{p.dockLabel}</li>)}
        </ul>
        <p class="svc-note">
          Every engagement is led by a named independent professional who remains
          responsible for the work.
        </p>
      </aside>
    </div>
  </section>

  <CtaBand />
</Base>

<style>
  .svc-hero {
    padding: calc(var(--header-h) + clamp(3rem, 7vw, 5.5rem)) 0 clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--charcoal-2);
    background: var(--charcoal);
  }

  .svc-hero h1 {
    font-size: var(--text-h2);
    margin-top: 0.9rem;
    position: relative;
  }

  .svc-intro {
    color: var(--grey);
    max-width: 46rem;
    margin-top: 1rem;
    position: relative;
  }

  .svc-body {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  .svc-body h2 {
    font-size: var(--text-h3);
    margin-bottom: 1.2rem;
  }

  .covers {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.8rem;
    max-width: 36rem;
  }

  .covers li {
    padding-left: 1.6rem;
    position: relative;
    color: var(--silver);
    font-size: 0.95rem;
  }

  .covers li::before {
    content: "+";
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: 700;
  }

  .svc-aside {
    border: 1px solid var(--charcoal-2);
    border-top: 2px solid var(--gold-30);
    border-radius: var(--radius);
    padding: 1.6rem 1.5rem;
    background: var(--charcoal);
  }

  .svc-platforms {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.2rem;
    display: grid;
    gap: 0.5rem;
    color: var(--silver);
    font-size: var(--text-small);
  }

  .svc-note {
    color: var(--grey);
    font-size: var(--text-micro);
    line-height: 1.6;
    border-top: 1px solid var(--charcoal-2);
    padding-top: 1rem;
  }

  @media (max-width: 800px) {
    .svc-body {
      grid-template-columns: 1fr;
    }
  }
</style>
