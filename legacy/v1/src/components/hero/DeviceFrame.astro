---
/**
 * CSS-built monitor: thin charcoal bezel, gold power LED, minimal stand,
 * soft gold backlight, floor reflection. The <slot /> receives the
 * screen stack (all recreated platform screens, absolutely stacked).
 */
---

<div class="device" id="hero-device" aria-hidden="true">
  <div class="device-glow"></div>

  <div class="device-tilt" id="device-tilt">
    <div class="device-frame">
      <div class="device-screen" id="device-screen">
        <div class="screen-stack" id="screen-stack">
          <slot />
        </div>
        <div class="device-glare" id="device-glare"></div>
      </div>
      <span class="device-led"></span>
    </div>

    <div class="device-stand"></div>
    <div class="device-base"></div>
  </div>

  <div class="device-reflection"></div>
</div>

<style>
  .device {
    position: relative;
    width: 100%;
    perspective: 1600px;
  }

  .device-glow {
    position: absolute;
    inset: -12% -10% 0;
    background: radial-gradient(
      ellipse 60% 52% at 50% 42%,
      rgba(207, 152, 47, 0.14),
      transparent 68%
    );
    filter: blur(6px);
    pointer-events: none;
  }

  .device-tilt {
    position: relative;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .device-frame {
    position: relative;
    background: linear-gradient(180deg, #17171a, #0c0c0e);
    border: 1px solid #232326;
    border-radius: 14px;
    padding: 10px;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.06) inset,
      0 40px 80px -24px rgba(0, 0, 0, 0.85),
      0 0 90px -30px rgba(207, 152, 47, 0.25);
  }

  .device-screen {
    position: relative;
    aspect-ratio: 1200 / 750;
    border-radius: 7px;
    overflow: hidden;
    background: #0b0b0b;
    /* hairline screen edge */
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.9);
  }

  .screen-stack {
    position: absolute;
    inset: 0;
  }

  .device-glare {
    position: absolute;
    inset: -40%;
    background: linear-gradient(
      115deg,
      transparent 42%,
      rgba(239, 196, 81, 0.1) 50%,
      rgba(255, 255, 255, 0.07) 54%,
      transparent 62%
    );
    opacity: 0;
    pointer-events: none;
    will-change: transform, opacity;
  }

  .device-led {
    position: absolute;
    left: 50%;
    bottom: 3px;
    translate: -50% 0;
    width: 22px;
    height: 3px;
    border-radius: 2px;
    background: var(--gold);
    box-shadow: 0 0 10px rgba(207, 152, 47, 0.8);
  }

  .device-stand {
    width: 12%;
    height: clamp(26px, 3.2vw, 44px);
    margin: 0 auto;
    background: linear-gradient(180deg, #131316, #0a0a0c);
    clip-path: polygon(18% 0, 82% 0, 100% 100%, 0 100%);
  }

  .device-base {
    width: 30%;
    height: 7px;
    margin: 0 auto;
    border-radius: 4px;
    background: linear-gradient(180deg, #1d1d21, #0d0d0f);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.7);
  }

  .device-reflection {
    position: absolute;
    left: 12%;
    right: 12%;
    top: 100%;
    height: 60px;
    background: radial-gradient(
      ellipse 50% 100% at 50% 0%,
      rgba(207, 152, 47, 0.1),
      transparent 70%
    );
    filter: blur(4px);
    pointer-events: none;
  }
</style>
