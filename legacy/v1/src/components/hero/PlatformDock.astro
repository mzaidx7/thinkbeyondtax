---
import { platformStates } from "../../data/platforms";
---

<div class="dock-wrap">
  <div class="dock" role="tablist" aria-label="Software platforms" id="platform-dock">
    {
      platformStates.map((p, i) => (
        <button
          type="button"
          role="tab"
          class="dock-tab"
          id={`dock-tab-${p.id}`}
          data-state-index={i + 1}
          aria-selected="false"
          tabindex={i === 0 ? 0 : -1}
          style={`--accent:${p.accent}`}
        >
          <span class="dock-tick" />
          {p.dockLabel}
          <i class="dock-progress" />
        </button>
      ))
    }
  </div>
  <p class="dock-hint" id="dock-hint">
    <span>Scroll to explore the platforms</span>
    <svg width="12" height="14" viewBox="0 0 12 14" aria-hidden="true">
      <path d="M6 1v10M2 8l4 4 4-4" fill="none" stroke="currentColor" stroke-width="1.5" />
    </svg>
  </p>
</div>

<style>
  .dock-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    align-items: flex-start;
  }

  .dock {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .dock-tab {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.95rem;
    border: 1px solid var(--charcoal-3);
    border-radius: var(--radius-pill);
    background: rgba(11, 11, 11, 0.7);
    color: var(--grey);
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    white-space: nowrap;
    overflow: hidden;
    transition:
      color 0.3s var(--ease-out),
      border-color 0.3s var(--ease-out),
      background 0.3s var(--ease-out);
  }

  .dock-tab:hover {
    color: var(--silver);
    border-color: var(--gold-30);
  }

  .dock-tab[aria-selected="true"] {
    color: var(--silver);
    border-color: var(--gold);
    background: var(--gold-08);
  }

  .dock-tick {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    opacity: 0.55;
    flex: none;
    transition: opacity 0.3s;
  }

  .dock-tab[aria-selected="true"] .dock-tick {
    opacity: 1;
    box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 70%, transparent);
  }

  .dock-progress {
    position: absolute;
    left: 0;
    bottom: 0;
    height: 2px;
    width: 100%;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: left;
  }

  .dock-hint {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    color: var(--grey);
    transition: opacity 0.6s var(--ease-out);
  }

  .dock-hint svg {
    animation: hint-bob 1.8s ease-in-out infinite;
  }

  .dock-hint.hidden {
    opacity: 0;
  }

  @keyframes hint-bob {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(4px);
    }
  }
</style>
