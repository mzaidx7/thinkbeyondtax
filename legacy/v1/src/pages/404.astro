---
import Base from "../layouts/Base.astro";
---

<Base title="Page not found — Think Beyond Tax">
  <section class="nf hex-bg">
    <div class="container nf-inner">
      <p class="overline">404</p>
      <h1>This page doesn't balance.</h1>
      <p>The page you're looking for doesn't exist or has moved.</p>
      <a class="btn btn-gold" href="/">Back to home</a>
    </div>
  </section>
</Base>

<style>
  .nf {
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding-top: var(--header-h);
  }

  .nf-inner {
    position: relative;
    display: grid;
    gap: 1.1rem;
    justify-items: start;
  }

  .nf h1 {
    font-size: var(--text-h2);
  }

  .nf p {
    color: var(--grey);
  }
</style>
