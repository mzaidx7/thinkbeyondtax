---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_NAME, SITE_TAGLINE } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${SITE_NAME} — Accounting, Bookkeeping & UAE Tax Support`,
  description = `${SITE_TAGLINE}. Practical support with bookkeeping, accounting, financial reporting, VAT and Corporate Tax — inside TallyPrime, QuickBooks, Zoho Books, Xero and EmaraTax.`,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/brand/favicon-512.png" />
    <meta name="theme-color" content="#030304" />
    <link rel="icon" type="image/png" sizes="32x32" href="/brand/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/brand/favicon-64.png" />
    <link rel="apple-touch-icon" href="/brand/tbt-app-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lato:wght@300;900&display=swap"
    />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
