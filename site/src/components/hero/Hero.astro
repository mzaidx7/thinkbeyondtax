---
import DeviceFrame from "./DeviceFrame.astro";
import PlatformDock from "./PlatformDock.astro";
import ScreenIntro from "./screens/ScreenIntro.astro";
import ScreenTally from "./screens/ScreenTally.astro";
import ScreenQbo from "./screens/ScreenQbo.astro";
import ScreenQbd from "./screens/ScreenQbd.astro";
import ScreenZoho from "./screens/ScreenZoho.astro";
import ScreenXero from "./screens/ScreenXero.astro";
import ScreenEmaraTax from "./screens/ScreenEmaraTax.astro";
import "./screens/screens.css";
import { heroStates } from "../../data/platforms";
import { WHATSAPP_URL, TRADEMARK_DISCLAIMER } from "../../data/site";
---

<section class="hero hex-bg" id="hero">
  <div class="hero-pin" id="hero-pin">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="overline hero-overline">
          Think Beyond Tax · Independent UAE accounting &amp; tax professionals
        </p>

        <div class="hero-swap hero-swap-h" id="swap-headlines">
          {
            heroStates.map((s, i) =>
              i === 0 ? (
                <h1 class="hero-headline" data-state-index={i}>
                  {s.headline}
                </h1>
              ) : (
                <p class="hero-headline" role="heading" aria-level="2" data-state-index={i}>
                  {s.headline}
                </p>
              ),
            )
          }
        </div>

        <div class="hero-swap hero-swap-p" id="swap-supports">
          {
            heroStates.map((s, i) => (
              <p class="hero-support" data-state-index={i}>
                {s.support}
              </p>
            ))
          }
        </div>

        <div class="hero-swap hero-swap-c" id="swap-chips">
          {
            heroStates.map((s, i) => (
              <ul class="hero-chips" data-state-index={i}>
                {s.chips.map((c) => (
                  <li>{c}</li>
                ))}
              </ul>
            ))
          }
        </div>

        <div class="hero-ctas">
          <a class="btn btn-gold" href={WHATSAPP_URL} target="_blank" rel="noopener">
            Discuss Your Requirements
          </a>
          <a class="btn btn-ghost" href="/services">Explore Our Services</a>
        </div>

        <PlatformDock />
        <span class="visually-hidden" aria-live="polite" id="hero-announcer"></span>
      </div>

      <div class="hero-stage">
        <DeviceFrame>
          <ScreenIntro />
          <ScreenTally />
          <ScreenQbo />
          <ScreenQbd />
          <ScreenZoho />
          <ScreenXero />
          <ScreenEmaraTax />
        </DeviceFrame>
      </div>
    </div>
  </div>
</section>

<p class="hero-disclaimer container">{TRADEMARK_DISCLAIMER}</p>

<style>
  .hero {
    position: relative;
  }

  .hero-pin {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--header-h);
    position: relative;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 44fr 56fr;
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: center;
  }

  .hero-overline {
    margin-bottom: 1.4rem;
  }

  /* stacked swap regions — hero.ts sizes them to the tallest child */
  .hero-swap {
    position: relative;
  }

  .hero-swap > * {
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    opacity: 0;
    visibility: hidden;
  }

  .hero-swap > *.is-current {
    opacity: 1;
    visibility: visible;
  }

  .hero-swap-h {
    min-height: 8.2rem;
  }

  .hero-swap-p {
    min-height: 6.4rem;
    margin-top: 1.1rem;
  }

  .hero-swap-c {
    min-height: 2.4rem;
    margin-top: 0.4rem;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: var(--text-hero);
    line-height: 1.12;
    color: var(--silver);
    letter-spacing: -0.01em;
  }

  .hero-support {
    color: var(--grey);
    font-size: 1.02rem;
    line-height: 1.65;
    max-width: 34rem;
  }

  .hero-chips {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1.3rem;
  }

  .hero-chips li {
    font-size: var(--text-micro);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-chips li::before {
    content: "+";
    color: var(--gold-lo);
    font-weight: 600;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin: 1.8rem 0 2rem;
  }

  .hero-stage {
    position: relative;
  }

  .hero-disclaimer {
    font-size: var(--text-micro);
    color: var(--grey);
    opacity: 0.75;
    line-height: 1.6;
    max-width: 56rem;
    padding-block: 1.2rem 0;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 1023px) {
    .hero-pin {
      min-height: auto;
      padding-top: calc(var(--header-h) + 2.5rem);
      padding-bottom: 2rem;
    }

    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .hero-swap-h {
      min-height: 7rem;
    }

    .hero-stage {
      touch-action: pan-y;
    }
  }
</style>

<script>
  import { initHero } from "./hero";
  initHero();
</script>
