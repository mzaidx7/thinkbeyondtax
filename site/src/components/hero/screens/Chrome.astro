---
/**
 * Shared window chrome for the recreated screens.
 * variant "browser": dark tab strip + URL bar (web apps).
 * variant "windows": dark app title bar (desktop apps).
 */
interface Props {
  variant: "browser" | "windows";
  title: string;
  url?: string;
  accent?: string;
}

const { variant, title, url = "", accent = "#cf982f" } = Astro.props;
---

{
  variant === "browser" ? (
    <div class="chrome chrome-browser" style={`--accent:${accent}`}>
      <div class="tab-strip">
        <span class="traffic" aria-hidden="true">
          <i /> <i /> <i />
        </span>
        <span class="tab">
          <span class="tab-dot" />
          <span class="tab-title">{title}</span>
          <span class="tab-x">×</span>
        </span>
        <span class="tab-plus">+</span>
      </div>
      <div class="url-bar">
        <span class="nav-arrows">
          <svg width="14" height="14" viewBox="0 0 14 14"><path d="M9 2 4 7l5 5" fill="none" stroke="#9a9a9a" stroke-width="1.6" /></svg>
          <svg width="14" height="14" viewBox="0 0 14 14"><path d="m5 2 5 5-5 5" fill="none" stroke="#5c5c5c" stroke-width="1.6" /></svg>
          <svg width="13" height="13" viewBox="0 0 14 14"><path d="M12 7a5 5 0 1 1-1.5-3.6M12 1v3h-3" fill="none" stroke="#9a9a9a" stroke-width="1.5" /></svg>
        </span>
        <span class="url-pill">
          <svg width="10" height="12" viewBox="0 0 10 12" aria-hidden="true"><rect x="1" y="5" width="8" height="6" rx="1" fill="#8a8a8a" /><path d="M3 5V3.5a2 2 0 0 1 4 0V5" fill="none" stroke="#8a8a8a" stroke-width="1.4" /></svg>
          <span class="url-text">{url}</span>
        </span>
        <span class="menu-dots">⋮</span>
      </div>
    </div>
  ) : (
    <div class="chrome chrome-windows" style={`--accent:${accent}`}>
      <span class="win-dot" />
      <span class="win-title">{title}</span>
      <span class="win-controls">
        <svg width="10" height="10" viewBox="0 0 10 10"><path d="M1 5h8" stroke="#9a9a9a" stroke-width="1.2" /></svg>
        <svg width="10" height="10" viewBox="0 0 10 10"><rect x="1.5" y="1.5" width="7" height="7" fill="none" stroke="#9a9a9a" stroke-width="1.2" /></svg>
        <svg width="10" height="10" viewBox="0 0 10 10"><path d="M1.5 1.5 8.5 8.5M8.5 1.5 1.5 8.5" stroke="#9a9a9a" stroke-width="1.2" /></svg>
      </span>
    </div>
  )
}

<style>
  .chrome {
    position: relative;
    z-index: 3;
    user-select: none;
    font-family: var(--font-body);
  }

  /* ---- browser ---- */
  .chrome-browser .tab-strip {
    height: 38px;
    background: #1b1b1e;
    display: flex;
    align-items: flex-end;
    padding: 0 14px;
    gap: 10px;
  }

  .traffic {
    display: flex;
    gap: 7px;
    align-self: center;
    margin-right: 6px;
  }

  .traffic i {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #3d3d42;
  }

  .tab {
    display: flex;
    align-items: center;
    gap: 9px;
    background: #2b2b2f;
    border-radius: 9px 9px 0 0;
    padding: 8px 14px;
    min-width: 230px;
    font-size: 12.5px;
    color: #d9d9d9;
  }

  .tab-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }

  .tab-title {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 200px;
  }

  .tab-x {
    color: #7a7a7a;
    margin-left: auto;
  }

  .tab-plus {
    color: #7a7a7a;
    font-size: 16px;
    align-self: center;
  }

  .chrome-browser .url-bar {
    height: 40px;
    background: #2b2b2f;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 16px;
  }

  .nav-arrows {
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .url-pill {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 8px;
    background: #1e1e21;
    border-radius: 999px;
    padding: 6px 14px;
    font-size: 12px;
    color: #bdbdbd;
    letter-spacing: 0.01em;
  }

  .menu-dots {
    color: #9a9a9a;
    font-size: 14px;
  }

  /* ---- windows ---- */
  .chrome-windows {
    height: 40px;
    background: #1b1b1e;
    display: flex;
    align-items: center;
    padding: 0 16px;
    gap: 10px;
  }

  .win-dot {
    width: 10px;
    height: 10px;
    border-radius: 2px;
    background: var(--accent);
    flex: none;
  }

  .win-title {
    font-size: 12.5px;
    color: #d9d9d9;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .win-controls {
    margin-left: auto;
    display: flex;
    gap: 18px;
    align-items: center;
  }
</style>
