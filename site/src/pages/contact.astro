---
import Base from "../layouts/Base.astro";
import { EMAIL, PHONE_DISPLAY, WHATSAPP_URL } from "../data/site";
---

<Base title="Contact — Think Beyond Tax">
  <section class="svc-hero hex-bg">
    <div class="container">
      <p class="overline">Contact</p>
      <h1>Discuss your requirements</h1>
      <p class="svc-intro">
        Tell us how your records are kept and what you need — we'll connect you
        with the right independent professional. No obligation, no hard sell.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">
      <div class="channels">
        <a class="channel" href={WHATSAPP_URL} target="_blank" rel="noopener">
          <p class="channel-label">WhatsApp</p>
          <p class="channel-value">{PHONE_DISPLAY}</p>
          <p class="channel-note">Usually the fastest way to reach us</p>
        </a>
        <a class="channel" href={`mailto:${EMAIL}`}>
          <p class="channel-label">Email</p>
          <p class="channel-value">{EMAIL}</p>
          <p class="channel-note">We reply within one working day</p>
        </a>
        <div class="channel channel-static">
          <p class="channel-label">Location</p>
          <p class="channel-value">United Arab Emirates</p>
          <p class="channel-note">Remote-first — on-site visits by arrangement</p>
        </div>
      </div>

      <!--
        Contact form posts to Web3Forms (https://web3forms.com).
        To activate: create a free access key for info@thinkbeyondtax.com and
        replace ACCESS_KEY_PLACEHOLDER below.
      -->
      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
      >
        <input type="hidden" name="access_key" value="ACCESS_KEY_PLACEHOLDER" />
        <input type="hidden" name="subject" value="New enquiry — thinkbeyondtax.com" />
        <input type="checkbox" name="botcheck" class="hp" tabindex="-1" autocomplete="off" />

        <div class="field-row">
          <label>
            Name
            <input type="text" name="name" required autocomplete="name" />
          </label>
          <label>
            Company
            <input type="text" name="company" autocomplete="organization" />
          </label>
        </div>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
        <label>
          What do you need help with?
          <select name="topic">
            <option>Bookkeeping</option>
            <option>Accounting</option>
            <option>VAT</option>
            <option>Corporate Tax</option>
            <option>Not sure yet</option>
          </select>
        </label>
        <label>
          Message
          <textarea
            name="message"
            rows="5"
            required
            placeholder="Tell us about your business, the software you use, and what you need."></textarea>
        </label>
        <button class="btn btn-gold" type="submit">Send Enquiry</button>
        <p class="form-status" id="form-status" role="status"></p>
      </form>
    </div>
  </section>
</Base>

<style>
  .svc-hero {
    padding: calc(var(--header-h) + clamp(3rem, 7vw, 5.5rem)) 0 clamp(2.5rem, 5vw, 4rem);
    border-bottom: 1px solid var(--charcoal-2);
    background: var(--charcoal);
  }

  .svc-hero h1 {
    font-size: var(--text-h2);
    margin-top: 0.9rem;
    position: relative;
  }

  .svc-intro {
    color: var(--grey);
    max-width: 44rem;
    margin-top: 1rem;
    position: relative;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: clamp(2.5rem, 5vw, 5rem);
    align-items: start;
  }

  .channels {
    display: grid;
    gap: 1rem;
  }

  .channel {
    display: block;
    border: 1px solid var(--charcoal-2);
    border-radius: var(--radius);
    background: var(--charcoal);
    padding: 1.4rem 1.5rem;
    transition: border-color var(--dur) var(--ease-out);
  }

  a.channel:hover {
    border-color: var(--gold-30);
  }

  .channel-label {
    font-size: var(--text-micro);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .channel-value {
    font-weight: 600;
    margin-top: 0.4rem;
  }

  .channel-note {
    color: var(--grey);
    font-size: var(--text-small);
    margin-top: 0.2rem;
  }

  form {
    display: grid;
    gap: 1.1rem;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem;
  }

  label {
    display: grid;
    gap: 0.45rem;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--silver);
  }

  input,
  select,
  textarea {
    background: var(--charcoal);
    border: 1px solid var(--charcoal-3);
    border-radius: var(--radius);
    color: var(--silver);
    font: inherit;
    padding: 0.7rem 0.9rem;
    transition: border-color 0.3s var(--ease-out);
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  textarea {
    resize: vertical;
  }

  .hp {
    display: none;
  }

  form .btn {
    justify-self: start;
  }

  .form-status {
    font-size: var(--text-small);
    color: var(--gold-hi);
    min-height: 1.2em;
  }

  @media (max-width: 800px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("form-status");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!status) return;

    const key = (form.querySelector('[name="access_key"]') as HTMLInputElement)?.value;
    if (!key || key === "ACCESS_KEY_PLACEHOLDER") {
      status.textContent =
        "The form isn't connected yet — please reach us on WhatsApp or email instead.";
      return;
    }

    status.textContent = "Sending…";
    try {
      const res = await fetch(form.action, {
        method: "POST",
        body: new FormData(form),
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        form.reset();
        status.textContent = "Thank you — we'll get back to you within one working day.";
      } else {
        throw new Error(String(res.status));
      }
    } catch {
      status.textContent =
        "Something went wrong — please reach us on WhatsApp or email instead.";
    }
  });
</script>
